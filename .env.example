# Copy to `.env` and fill in real values. `.env` is gitignored.

# PostgreSQL connection string used by Prisma (migrations + runtime).
DATABASE_URL="postgresql://user:password@localhost:5432/logiclings?schema=public"

# Better Auth signing secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-random-secret"

# Base URL Better Auth issues callbacks/cookies against.
# Local dev: http://localhost:5173 — production: the deployed origin.
BETTER_AUTH_URL="http://localhost:5173"
