// Logiclings data model.
//
// Auth models (User, Session, Account, Verification) follow the Better Auth
// core schema and are managed through the Better Auth Prisma adapter.
// Progress models (UserProgress, Attempt) follow the Core Data Models in
// context/project-overview.md.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

/// Mastery a learner has reached on a lesson.
enum MasteryState {
  not_started
  discovering
  applied
  mastered
}

/// How a single play attempt ended.
enum AttemptOutcome {
  completed
  failed
  abandoned
}

// --- Better Auth core models ---

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions     Session[]
  accounts     Account[]
  progress     UserProgress[]
  attempts     Attempt[]
  streak       Streak?
  achievements UserAchievement[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// --- Progress models ---

/// One row per (user, lesson). Records the learner's current mastery and the
/// lesson version that mastery was earned against.
model UserProgress {
  id            String       @id @default(cuid())
  userId        String
  lessonId      String
  masteryState  MasteryState @default(not_started)
  bestScore     Int?
  attempts      Int          @default(0)
  completedAt   DateTime?
  lastPlayedAt  DateTime?
  lessonVersion Int          @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("user_progress")
}

/// One row per play attempt. `clientAttemptId` is generated on the client and
/// makes the completion mutation idempotent: replaying the same attempt is a
/// no-op rather than a double count.
model Attempt {
  id              String         @id @default(cuid())
  userId          String
  lessonId        String
  levelId         String
  startedAt       DateTime
  completedAt     DateTime?
  outcome         AttemptOutcome
  score           Int?
  mistakeCodes    String[]
  hintCount       Int            @default(0)
  durationMs      Int?
  clientAttemptId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientAttemptId])
  @@index([userId, lessonId])
  @@map("attempt")
}

/// One row per user. `lastQualifiedDate` is a calendar date (`YYYY-MM-DD`) in
/// `timezone`, not an instant — streak math compares local calendar days, so
/// storing it pre-resolved to the user's timezone keeps DST transitions out of
/// every read.
model Streak {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentDays       Int      @default(0)
  longestDays       Int      @default(0)
  lastQualifiedDate String?
  timezone          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streak")
}

/// A definition a learner can earn, per the Core Data Models. Rows are
/// upserted by slug from the local achievement catalog (`src/achievements`)
/// the first time the achievement service evaluates them, so the catalog
/// stays the single typed source of truth for title/description/iconKey.
model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  iconKey     String

  createdAt DateTime @default(now())

  earnedBy UserAchievement[]

  @@map("achievement")
}

/// One row per (user, achievement) the user has earned. Awarding is
/// idempotent on this pair — evaluating the same qualifying event twice
/// never earns an achievement a second time.
model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievement")
}
